# ============================================================
# EntradasJujuy — Variables de entorno
# ============================================================
# Copiar este archivo como .env y completar los valores

# ── Base de datos PostgreSQL ──────────────────────────────────
DATABASE_URL=postgresql://postgres:TU_PASSWORD@localhost:5432/entradasjujuy

# ── MercadoPago ───────────────────────────────────────────────
# Obtener en: https://www.mercadopago.com.ar/developers/panel/app
MP_ACCESS_TOKEN=APP_USR-tu-token-de-mercadopago
MP_PUBLIC_KEY=APP_USR-tu-public-key
MP_CLIENT_ID=tu-client-id
# Opcional: las apps modernas pueden usar OAuth con PKCE sin Client Secret.
MP_CLIENT_SECRET=
MP_OAUTH_PKCE=true
MP_REDIRECT_URI=http://localhost:3001/api/mercadopago/oauth/callback
MP_MARKETPLACE_FEE_PERCENT=10

# ── JWT Secret ────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=pegar_aqui_un_hash_aleatorio_largo

# ── Google Login ──────────────────────────────────────────────
# Crear OAuth Client ID web en Google Cloud Console
GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com

# ── Email (SMTP) ──────────────────────────────────────────────
# Para desarrollo: usar Mailtrap (https://mailtrap.io)
# Para producción: configurar con tu proveedor SMTP real
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=tu_usuario_smtp
SMTP_PASS=tu_password_smtp
SMTP_FROM=entradasjujuy@gmail.com

# ── URLs ──────────────────────────────────────────────────────
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# ── CORS (opcional) ───────────────────────────────────────────
# En producción, poner el dominio del frontend: https://entradasjujuy.com
# CORS_ORIGIN=https://entradasjujuy.com

# ── Entorno ───────────────────────────────────────────────────
# NODE_ENV=production
